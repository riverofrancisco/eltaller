  "reviews": [
    {
      "id": "testimonio-1",
      "name": "Sara Beatriz",
      "text": "Es un espacio de paz, conexión y placer vinculado a la música. Hace bien al alma, y nos permite crecer a nuestro ritmo potenciando nuestras cualidades. ¡No se lo pueden perder!",
      "stars": 5
    },
    {
      "id": "testimonio-2",
      "name": "Maximo Bence",
      "text": "La mejor forma de introducirse en el mundo del canto. El nivel de humanidad de las clases convierte en realidad el dicho: 'quien canta, sus males espanta'. Una experiencia que hay que vivir.",
      "stars": 5
    },
    {
      "id": "testimonio-3",
      "name": "Lilian Cafaro",
      "text": "Hermoso momento compartido con gente maravillosa. Un espacio cálido y profesional.",
      "stars": 5
    }
  ]
